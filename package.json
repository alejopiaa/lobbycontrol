{
  "name": "lobbycontrol",
  "version": "2.5.0",
  "description": "Sistema local para la gestión y control de audiencias de la Ley de Lobby",
  "main": "main.js",
  "scripts": {
    "import-lobby": "node scripts/import_lobby.js",
    "check-db": "node scripts/check_db.js",
    "inspect-db": "node scripts/inspect.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --dir",
    "electron:installer": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "lobby",
    "sqlite",
    "express",
    "mvp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.lobbycontrol.app",
    "productName": "LobbyControl",
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "main.js",
      "preload.js",
      "src/**/*",
      "public/**/*",
      "scripts/import_lobby.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/lobby.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LobbyControl",
      "runAfterFinish": false,
      "deleteAppDataOnUninstall": false
    },
    "asar": true,
    "asarUnpack": [
      "scripts/import_lobby.js"
    ]
  }
}
